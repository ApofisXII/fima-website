{% extends 'public/base.html.twig' %}

{% block title %}{{ 'urbino_courses.page_title'|trans }} • Urbino Musica Antica • FIMA{% endblock %}
{% block title_suffix %}{% endblock %}

{% block body %}

    <div class="container">
        <h1 class="font-serif">{{ 'urbino_courses.heading'|trans }}</h1>

        <div>
            {% for courseInCategory in coursesInCategories %}

                <h2 class="courses-category-title">{{ app.request.locale == 'it' ? courseInCategory.category.nameIt : courseInCategory.category.nameEn }}</h2>
                <div class="courses-grid">
                    <div class="courses-grid__track">
                    {% for course in courseInCategory.courses %}
                        <div class="course-box" style="animation-delay: {{ loop.index0 * 0.1 }}s; {% if course.imageUploaded %}background-image: url('{{ asset('uploads-uma-courses/'~course.id~'.webp') }}');{% endif %}">
                            <div class="course-box__inner">
                                <div class="course-box__info-row">
                                    <div>
                                        <div class="course-box__title">{{ course.teacherFullName }}</div>
                                        <div class="course-box__subtitle">{{ app.locale == 'it' ? course.disciplineIt : course.disciplineEn }}</div>
                                    </div>
                                    <div class="chip chip--course-box {{ course.scheduleType == 'schedule_type_individual' ? 'chip--course-box-individual' }}">{{ course.scheduleType|trans }}</div>
                                </div>
                                <a class="hover btn btn--course-box" href="{{ path('urbinoCourseDetail', {'course':course.id, 'slug':course.slug}) }}">{{ 'urbino_courses.view_course'|trans }}</a>
                            </div>
                        </div>
                    {% endfor %}
                    </div>
                </div>

            {% endfor %}
        </div>
    </div>

{% endblock %}
