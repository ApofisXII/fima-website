{% extends 'admin/base.html.twig' %}

{% block body %}

    <div class="gg-h1">{{ issue ? 'Modifica' : 'Nuovo' }} numero Recercare</div>

    <form id="page-form" method="post" action="{{ path('adminRecercareIssuesDetailSave') }}">
        <input type="hidden" name="issueId" value="{{ issue ? issue.id : "0" }}">

        <div class="box multi-detail-box gg-form">
            <h3>{{ issue ? 'Recercare ' ~ issue.volume ~ ' (' ~ issue.year ~ ')' : 'Dettaglio numero' }}</h3>

            <div class="gg-form-row gg-form-row--no-margin gg-form-row--enrollment">
                <div class="course-date-field">
                    <label>Volume (numero)</label>
                    <input type="number" name="volume" placeholder="Es. 37" value="{{ issue ? issue.volume }}" required min="1">
                </div>

                <div class="course-date-field">
                    <label>Anno</label>
                    <input type="number" name="year" placeholder="Es. 2025" value="{{ issue ? issue.year }}" required min="1989">
                </div>

                <div class="course-date-field">
                    <label>ISBN (facoltativo)</label>
                    <input type="text" name="isbn" placeholder="Es. 978-88-..." value="{{ issue ? issue.isbn }}">
                </div>
            </div>

            <label>Nota (facoltativa)</label>
            <input type="text" name="note" placeholder="Es. In memoria di Marco Di Pasquale" value="{{ issue ? issue.note }}">

            <div class="gg-checkbox-group">
                <label>
                    <input type="checkbox" name="isPublic" value="1" {{ issue and issue.isPublic ? 'checked' }}>
                    <span>Numero visibile pubblicamente</span>
                </label>
                <label>
                    <input type="checkbox" name="hasSummary" value="1" {{ issue and issue.hasSummary ? 'checked' }}>
                    <span>L'indice include anche il sommario</span>
                </label>
            </div>
        </div>

        <div class="box multi-detail-box gg-form">
            <h3>Copertina</h3>

            {% if issue and issue.hasCover %}
                <p><img src="{{ asset('uploads-recercare/covers/' ~ issue.id ~ '.webp') }}" alt="Copertina" style="max-height: 200px;"></p>
            {% endif %}

            <label>{{ issue and issue.hasCover ? 'Sostituisci copertina' : 'Carica immagine copertina' }}</label>
            <input type="file" id="cover-input" name="cover" accept="image/*">

            {% if issue and issue.hasCover %}
                <div class="gg-action-btn-group">
                    <button type="button" id="delete-cover-btn" class="gg-action-btn gg-action-btn--delete hoverizzato">Elimina copertina</button>
                </div>
            {% endif %}
        </div>

        <div class="box multi-detail-box gg-form">
            <h3>Indice e sommario (italiano)</h3>

            {% if issue and issue.hasIndexIt %}
                <p><a href="{{ asset('uploads-recercare/indexes/' ~ issue.id ~ '_it.pdf') }}" target="_blank">Visualizza PDF caricato</a></p>
            {% endif %}

            <label>{{ issue and issue.hasIndexIt ? 'Sostituisci PDF (italiano)' : 'Carica PDF (italiano)' }}</label>
            <input type="file" id="index-it-input" name="indexIt" accept="application/pdf">

            {% if issue and issue.hasIndexIt %}
                <div class="gg-action-btn-group">
                    <button type="button" id="delete-index-it-btn" class="gg-action-btn gg-action-btn--delete hoverizzato">Elimina PDF italiano</button>
                </div>
            {% endif %}
        </div>

        <div class="box multi-detail-box gg-form">
            <h3>Indice e sommario (inglese)</h3>

            {% if issue and issue.hasIndexEn %}
                <p><a href="{{ asset('uploads-recercare/indexes/' ~ issue.id ~ '_en.pdf') }}" target="_blank">Visualizza PDF caricato</a></p>
            {% endif %}

            <label>{{ issue and issue.hasIndexEn ? 'Sostituisci PDF (inglese)' : 'Carica PDF (inglese)' }}</label>
            <input type="file" id="index-en-input" name="indexEn" accept="application/pdf">

            {% if issue and issue.hasIndexEn %}
                <div class="gg-action-btn-group">
                    <button type="button" id="delete-index-en-btn" class="gg-action-btn gg-action-btn--delete hoverizzato">Elimina PDF inglese</button>
                </div>
            {% endif %}
        </div>

        <div class="gg-btn-group">
            <button type="submit" class="gg-submit-btn hoverizzato">Salva numero</button>
            {% if issue %}
                <button id="delete-btn" class="gg-delete-btn hoverizzato">Elimina numero</button>
            {% endif %}
        </div>

    </form>

    {% if issue %}
        <div id="delete-modal" class="gg-modal" style="display: none;">
            <div class="gg-modal-content">
                <p>Confermi di voler eliminare questo numero?</p>
                <div class="gg-modal-buttons">
                    <button id="confirm-delete" class="gg-modal-btn gg-modal-btn--danger">Sì, elimina</button>
                    <button id="cancel-delete" class="gg-modal-btn gg-modal-btn--cancel">Annulla</button>
                </div>
            </div>
        </div>
    {% endif %}

{% endblock %}

{% block js %}

    <script type="module">

        const uploadBase = '{{ path('adminRecercareIssuesList') | replace({'recercare': 'recercare'}) }}';

        document.getElementById('page-form').addEventListener('submit', async function(e) {
            e.preventDefault();

            const formData = new FormData(e.target);
            const isPublic = formData.get('isPublic') === '1';
            const hasSummary = formData.get('hasSummary') === '1';

            const payload = {
                issueId:    formData.get('issueId'),
                volume:     formData.get('volume')  ? parseInt(formData.get('volume'))  : null,
                year:       formData.get('year')     ? parseInt(formData.get('year'))     : null,
                isbn:       formData.get('isbn') || null,
                note:       formData.get('note') || null,
                isPublic:   isPublic,
                hasSummary: hasSummary,
            };

            // 1. Salva i dati dell'entità
            let saveData;
            try {
                const saveRes = await fetch('{{ path('adminRecercareIssuesDetailSave') }}', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload),
                });
                saveData = await saveRes.json();
                if (!saveRes.ok) { alert(saveData.message || 'Errore nel salvataggio'); return; }
            } catch (err) {
                alert('Errore: ' + err.message);
                return;
            }

            const issueId = saveData.issueId ?? payload.issueId;

            // 2. Upload copertina se selezionata
            const coverFile = document.getElementById('cover-input').files[0];
            if (coverFile) {
                const fd = new FormData();
                fd.append('cover', coverFile);
                const r = await fetch('/admin/recercare/upload-cover/' + issueId, { method: 'POST', body: fd });
                if (!r.ok) { const d = await r.json(); alert('Errore copertina: ' + d.message); }
            }

            // 3. Upload indice italiano se selezionato
            const indexItFile = document.getElementById('index-it-input').files[0];
            if (indexItFile) {
                const fd = new FormData();
                fd.append('indexIt', indexItFile);
                const r = await fetch('/admin/recercare/upload-index-it/' + issueId, { method: 'POST', body: fd });
                if (!r.ok) { const d = await r.json(); alert('Errore indice IT: ' + d.message); }
            }

            // 4. Upload indice inglese se selezionato
            const indexEnFile = document.getElementById('index-en-input').files[0];
            if (indexEnFile) {
                const fd = new FormData();
                fd.append('indexEn', indexEnFile);
                const r = await fetch('/admin/recercare/upload-index-en/' + issueId, { method: 'POST', body: fd });
                if (!r.ok) { const d = await r.json(); alert('Errore indice EN: ' + d.message); }
            }

            location.href = "{{ path('adminRecercareIssuesList') }}";
        });

        {% if issue and issue.hasCover %}
        document.getElementById('delete-cover-btn').addEventListener('click', function() {
            if (!confirm('Confermi di voler eliminare la copertina?')) return;
            fetch('{{ path('adminRecercareIssuesDeleteCover', {'issueId': issue.id}) }}', { method: 'DELETE' })
            .then(async r => { const d = await r.json(); if (!r.ok) { alert(d.message); return null; } return d; })
            .then(d => { if (d) location.reload(); });
        });
        {% endif %}

        {% if issue and issue.hasIndexIt %}
        document.getElementById('delete-index-it-btn').addEventListener('click', function() {
            if (!confirm('Confermi di voler eliminare il PDF italiano?')) return;
            fetch('{{ path('adminRecercareIssuesDeleteIndexIt', {'issueId': issue.id}) }}', { method: 'DELETE' })
            .then(async r => { const d = await r.json(); if (!r.ok) { alert(d.message); return null; } return d; })
            .then(d => { if (d) location.reload(); });
        });
        {% endif %}

        {% if issue and issue.hasIndexEn %}
        document.getElementById('delete-index-en-btn').addEventListener('click', function() {
            if (!confirm('Confermi di voler eliminare il PDF inglese?')) return;
            fetch('{{ path('adminRecercareIssuesDeleteIndexEn', {'issueId': issue.id}) }}', { method: 'DELETE' })
            .then(async r => { const d = await r.json(); if (!r.ok) { alert(d.message); return null; } return d; })
            .then(d => { if (d) location.reload(); });
        });
        {% endif %}

        {% if issue %}
        const modal = document.getElementById('delete-modal');
        const deleteBtn = document.getElementById('delete-btn');

        deleteBtn.addEventListener('click', function(e) { e.preventDefault(); modal.style.display = 'flex'; });
        document.getElementById('cancel-delete').addEventListener('click', function() { modal.style.display = 'none'; });
        modal.addEventListener('click', function(e) { if (e.target === modal) modal.style.display = 'none'; });

        document.getElementById('confirm-delete').addEventListener('click', function() {
            modal.style.display = 'none';
            fetch('{{ path('adminRecercareIssuesDelete', {'issueId': issue.id}) }}', { method: 'DELETE' })
            .then(async r => { const d = await r.json(); if (!r.ok) { alert(d.message); return null; } return d; })
            .then(d => { if (d) location.href = "{{ path('adminRecercareIssuesList') }}"; });
        });
        {% endif %}

    </script>

{% endblock %}
